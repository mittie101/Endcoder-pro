{
  "name": "endcoder-pro",
  "version": "3.1.0",
  "description": "Professional Endcoder/Decoder with Monaco Editor, Image Optimization, JWT Tools, and Developer API",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node esbuild.config.js && npm install && electron-rebuild -f -w bcrypt,argon2,sharp",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w bcrypt,argon2,sharp",
    "test": "jest --verbose",
    "lint": "eslint . --ignore-pattern node_modules --ignore-pattern dist",
    "lint:fix": "eslint . --fix --ignore-pattern node_modules --ignore-pattern dist",
    "format": "prettier --write \"**/*.{js,json,css,md}\" --ignore-path .gitignore",
    "bundle": "node esbuild.config.js",
    "test:ci": "jest --verbose --coverage"
  },
  "keywords": [
    "base64",
    "encoder",
    "decoder",
    "jwt",
    "converter",
    "utility",
    "developer-tools",
    "monaco-editor",
    "image-optimization"
  ],
  "author": "Antony Morrison",
  "license": "MIT",
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^2.0.3",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "monaco-editor": "^0.45.0",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "argon2": "^0.31.2",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "qrious": "^4.0.2",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.endcoderpro.app",
    "productName": "Endcoder Pro",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "node_modules/bcrypt/**/*",
      "node_modules/argon2/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}",
      "!dist"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "fileAssociations": [
        {
          "ext": "b64",
          "name": "Base64 File",
          "description": "Base64 Encoded File"
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icon.png",
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "mittie101",
      "repo": "Endcoder-pro"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Endcoder Pro",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  }
}
